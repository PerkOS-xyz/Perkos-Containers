{
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "__PERKOS_LLM_PROVIDER__/__PERKOS_LLM_DEFAULT_MODEL__"
      }
    }
  },
  "gateway": {
    "port": 3000,
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "__PERKOS_GATEWAY_API_KEY__"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "__PERKOS_LLM_BASE_URL__",
        "apiKey": "__PERKOS_LLM_API_KEY__",
        "api": "__PERKOS_LLM_API__",
        "headers": {
          "x-agent-id": "__PERKOS_AGENT_ID__"
        },
        "models": [
          {
            "id": "__PERKOS_LLM_DEFAULT_MODEL__",
            "name": "__PERKOS_LLM_DEFAULT_MODEL__",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      }
    }
  }
}
