# PerkOS Assistant .env — copy to .env and fill in. Never commit .env.
#
# These values come from two places:
#   1. POST /api/agents/launch?kind=platform (a super-admin curl) — issues
#      PERKOS_AGENT_ID + PERKOS_RELAY_API_KEY. One-shot, save them now.
#   2. The LLM gateway's admin record for this VPS — PERKOS_LLM_API_KEY
#      is the magic key "allowlisted-vps-temporary" the gateway honors
#      for PerkOS-mode runtimes (see reference_llm_gateway memory).

# ---- Identity (from /api/agents/launch?kind=platform response) ----
# response.result.agent.id
PERKOS_AGENT_ID=
# response.credentials.relayApiKey  (the rk_… one-shot secret)
PERKOS_RELAY_API_KEY=

# ---- LLM gateway ----
PERKOS_LLM_BASE_URL=https://api.llm.perkos.xyz/v1
PERKOS_LLM_DEFAULT_MODEL=kimi-k2.6:cloud
PERKOS_LLM_API_KEY=allowlisted-vps-temporary

# ---- Bridges (defaults are fine) ----
PERKOS_CHAT_URL=wss://chat.perkos.xyz/chat
PERKOS_TRANSPORT_URL=wss://transport.perkos.xyz/a2a

# ---- Firebase Admin SDK (v2 — uncomment when user-scoped tools land) ----
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
